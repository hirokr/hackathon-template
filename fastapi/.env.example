DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/template_dev

# Sessions
SESSION_SECRET=change_me_session_secret
SESSION_MAX_AGE=86400
SESSION_COOKIE_SECURE=false

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# OAuth — Meta (Facebook)
META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# CORS
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=change_me_access_secret
REFRESH_JWT_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=5m
REFRESH_JWT_EXPIRES_IN=15d

# Cookies
ACCESS_TOKEN_COOKIE_NAME=accessToken
REFRESH_TOKEN_COOKIE_NAME=refreshToken
COOKIE_SECURE=false
COOKIE_SAMESITE=strict
COOKIE_DOMAIN=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@example.com
SUPPORT_EMAIL=support@example.com
